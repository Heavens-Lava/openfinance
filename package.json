{
  "name": "openfinance",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:app": "vite build --outDir dist-app --base ./",
    "electron": "electron .",
    "dist:win": "npm run build:app && electron-builder --win --publish never"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.jeffreymacy.openfinance",
    "productName": "OpenFinance",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist-app/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
